APP_NAME="Popup Hosting Overview Tool"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Filament: optionales Logo unter public/, Farben & UI-Tokens (config/filament-brand.php)
# FILAMENT_BRAND_LOGO=images/brand/popup-header-logo.png
# FILAMENT_BRAND_LOGO_HEIGHT=2.75rem
# FILAMENT_COLOR_PRIMARY=#d6002a
# FILAMENT_COLOR_SUCCESS=#0d6e4d
# FILAMENT_COLOR_WARNING=#b45309
# FILAMENT_COLOR_DANGER=#b42318
# FILAMENT_COLOR_INFO=#1d5a96
# FILAMENT_UI_BODY_BG=#fafafa
# FILAMENT_UI_PAGE_GAP_Y=2.5rem
# FILAMENT_UI_SECTION_PADDING=2rem

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=popup_hosting_overview_tool
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- API / n8n / Webhooks (Sanctum + Integrationen) ---
# Personal Access Token mit Ability "integrations" erstellen (siehe docs/n8n-api-and-webhooks.md)
SANCTUM_STATEFUL_DOMAINS=

WEBHOOK_BEARER_TOKEN_MOCO=
WEBHOOK_BEARER_TOKEN_MANAGEWP=
WEBHOOK_BEARER_TOKEN_AUTODNS=

WEBHOOK_HMAC_SECRET_MOCO=
WEBHOOK_HMAC_SECRET_MANAGEWP=
WEBHOOK_HMAC_SECRET_AUTODNS=
